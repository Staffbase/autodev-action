{
  "name": "autodev-action",
  "version": "v2.1.0",
  "description": "Github Action that tries to merge all commits from a PR with the dev label into the dev branch.",
  "author": "Staffbase GmbH",
  "keywords": [
    "actions",
    "git",
    "auto-dev",
    "auto-merge"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Staffbase/autodev-action.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "lint": "eslint --cache --no-error-on-unmatched-pattern src/",
    "fix": "eslint --cache --no-error-on-unmatched-pattern --fix src/",
    "test": "vitest run",
    "typecheck": "tsc",
    "build": "tsup",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "package": "ncc build --source-map --license licenses.txt",
    "all": "pnpm run build && pnpm run format && pnpm run lint && pnpm run package && pnpm run test"
  },
  "dependencies": {
    "@actions/core": "^1.10.1"
  },
  "devDependencies": {
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@babel/parser": "^7.24.7",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.6.0",
    "@octokit/openapi-types": "^22.2.0",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^20.14.9",
    "@vercel/ncc": "^0.38.1",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.6.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^15.7.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "prettier": "3.3.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^7.14.1",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@9.4.0"
}